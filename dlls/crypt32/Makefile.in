EXTRADEFS = -D_CRYPT32_
MODULE    = crypt32.dll
UNIXLIB   = crypt32.so
IMPORTLIB = crypt32
IMPORTS   = user32 advapi32 bcrypt
DELAYIMPORTS = cryptnet
UNIX_LIBS    = $(SECURITY_LIBS)
UNIX_CFLAGS  = $(GNUTLS_CFLAGS)

SOURCES = \
	base64.c \
	cert.c \
	chain.c \
	context.c \
	crl.c \
	crypt32.rc \
	ctl.c \
	decode.c \
	encode.c \
	main.c \
	message.c \
	msg.c \
	object.c \
	oid.c \
	pfx.c \
	proplist.c \
	protectdata.c \
	serialize.c \
	sip.c \
	store.c \
	store_collection.c \
	store_empty.c \
	store_file.c \
	store_memory.c \
	store_provider.c \
	store_registry.c \
	store_system.c \
	str.c \
	unixlib.c
